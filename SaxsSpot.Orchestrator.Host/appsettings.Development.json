{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  
  "kafka": {
    "brokers": ["localhost:9092"],
    "group": "scattering-calculation-result",
    "result-topic": "scattering.parallelepiped.calculate.result",
    "topic": "scattering.parallelepiped.calculate"
  },

  "ConnectionStrings": {
    "psql": "Host=localhost;Port=5432;Database=saxs;Username=postgres;Password=postgres;SearchPath=saxs"
  },

  "minio": {
    "accessKey": "s3user",
    "secretKey": "s3secretkey",
    "endpoint": "localhost:9000",
    "bucketName": "calculation"
  },
  "chart": {
    "uri": "http://localhost:1488"
  },
  "Auth":{
    "UseMock": "true"
  },
  "Grpc":{
    "UseMock": "false",
    "ServerAddress": "http://localhost:50051",
    "UseSsl": "false"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE"],
    "AllowedHeaders": ["Content-Type", "Authorization"],
    "AllowCredentials": true
  }
}
