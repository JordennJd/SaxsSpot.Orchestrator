{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  
  "kafka": {
    "brokers": ["kafka:29092"],
    "group": "scattering-calculation-result",
    "result-topic": "scattering.parallelepiped.calculate.result",
    "topic": "scattering.parallelepiped.calculate"
  },

  "ConnectionStrings": {
    "psql": "Host=orchestrator-db;Port=5432;Database=saxs;Username=postgres;Password=postgres;SearchPath=saxs"
  },

  "minio": {
    "accessKey": "s3user",
    "secretKey": "s3secretkey",
    "endpoint": "minio:9000",
    "bucketName": "calculation"
  },
  "chart": {
    "uri": "http://chart-service:1488"
  },
  "Auth":{
    "UseMock": "true"
  },
  "Grpc":{
    "UseMock": "false",
    "ServerAddress": "http://tracker-grpc-service:50051",
    "UseSsl": "false"
  }
}
